using (var context = new StudentManagementAPI.Data.ApplicationDbContext(
    new Microsoft.EntityFrameworkCore.DbContextOptionsBuilder<StudentManagementAPI.Data.ApplicationDbContext>()
        .UseSqlite("Data Source=app.db").Options))
{
    var user = context.Users.FirstOrDefault(u => u.Email == "admin@portal.com");
    if (user != null)
    {
        user.EmailConfirmed = true;
        context.SaveChanges();
        System.Console.WriteLine("Admin email confirmed.");
    }
}
